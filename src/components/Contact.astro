<section id="contact" aria-labelledby="contact-title">
  <div class="container">

    <div class="section-header fade-up">
      <span class="section-label">07 / Contact</span>
      <h2 class="section-title" id="contact-title">
        Get In <span>Touch</span>
      </h2>
      <div class="divider"></div>
    </div>

    <div class="contact-wrap fade-up d1">
      <p class="contact-intro">
        I'm currently open to new opportunities. Whether it's a job, collaboration, or just
        a data engineering conversation — my inbox is open.
      </p>

      <div class="contact-grid">

        <!-- Contact card -->
        <div class="contact-links card">
          <h3 class="contact-links-title">Reach Out</h3>

          <a href="mailto:vijayashreeua@gmail.com" class="contact-item">
            <span class="contact-item-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            <div>
              <p class="contact-item-label">Email</p>
              <p class="contact-item-value">vijayashreeua@gmail.com</p>
            </div>
          </a>

          <a href="https://github.com/vijayashreeua-afk" target="_blank" rel="noopener noreferrer"
             class="contact-item">
            <span class="contact-item-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                   fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577
