                         v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771
                         24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </span>
            <div>
              <p class="contact-item-label">LinkedIn</p>
              <p class="contact-item-value">linkedin.com/in/vijayashree-ashok</p>
            </div>
          </a>
        </div>

        <!-- Quick contact form (Formspree) -->
        <form
          class="contact-form card"
          action="https://formspree.io/f/mojraqyz"
          method="POST"
          novalidate
        >
          <h3 class="contact-links-title">Send a Message</h3>
          <!-- 
            TO ACTIVATE THIS FORM (free, no backend needed):
            1. Go to https://formspree.io and sign up with vijayashreeua@gmail.com
            2. Create a new form → copy the 8-char Form ID (e.g. xpwzjkqb)
            3. Replace YOUR_FORM_ID above with that ID
            Emails will be delivered to vijayashreeua@gmail.com automatically.
          -->

          <div class="form-row">
            <div class="form-group">
              <label for="cf-name">Name</label>
              <input type="text" id="cf-name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="cf-email">Email</label>
              <input type="email" id="cf-email" name="email" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="cf-message">Message</label>
            <textarea id="cf-message" name="message" rows="5"
                      placeholder="What's on your mind?" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">
            Send Message
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>

      </div>
    </div>

  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container footer-inner">
    <p>Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> &
       deployed on <a href="https://pages.cloudflare.com" target="_blank" rel="noopener">Cloudflare Pages</a></p>
    <p class="footer-copy">© 2026 Vijayashree Ashok · All rights reserved</p>
  </div>
</footer>

<style>
.contact-wrap { max-width: 900px; margin: 0 auto; }

.contact-intro {
  text-align: center;
  color: var(--text-secondary);
  font-size: 1.05rem;
  max-width: 560px;
  margin: 0 auto 2.5rem;
  line-height: 1.8;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 1.5rem;
  align-items: start;
}

.contact-links-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 1.25rem;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.85rem;
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  transition: background var(--transition);
  margin-bottom: 0.25rem;
}
.contact-item:hover { background: var(--accent-glow); color: var(--text-primary); }

.contact-item-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-glow);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--accent);
  flex-shrink: 0;
}

.contact-item-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.1rem;
}
.contact-item-value {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-primary);
}

/* Form */
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 1rem;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 1rem;
}
.form-group:last-of-type { margin-bottom: 1.25rem; }

label {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-secondary);
}

input, textarea {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0.7rem 0.9rem;
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: 0.93rem;
  transition: border-color var(--transition);
  resize: vertical;
}
input::placeholder, textarea::placeholder { color: var(--text-muted); }
input:focus, textarea:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}

/* Footer */
.footer {
  border-top: 1px solid var(--border);
  padding: 2rem 0;
  text-align: center;
}
.footer-inner {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  font-size: 0.85rem;
  color: var(--text-muted);
}
.footer-inner a { color: var(--accent); }
.footer-inner a:hover { color: var(--accent-warm); }
.footer-copy { font-size: 0.78rem; }

@media (max-width: 720px) {
  .contact-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
}
</style>
